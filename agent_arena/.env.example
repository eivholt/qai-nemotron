# Copy to agent_arena/.env and fill in locally.

AGENT_ARENA_PROVIDER=azure
AGENT_ARENA_MODEL_LABEL=azure_gpt

AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_API_KEY=

# Claude deployments in Microsoft Foundry use Anthropic's Foundry Messages API.
# If AGENT_ARENA_PROVIDER=azure and AZURE_OPENAI_DEPLOYMENT starts with claude-,
# the runner automatically uses the azure-foundry-anthropic provider path.
# Optional override:
ANTHROPIC_FOUNDRY_BASE_URL=
ANTHROPIC_FOUNDRY_API_KEY=

AGENT_ARENA_BASE_URL=
AGENT_ARENA_MODEL_NAME=
AGENT_ARENA_API_KEY=

# Local RTX/vLLM comparison, matching the OR Edge Agent repo.
# Start from /home/eivho/repos-native/or-edge-agent with:
#   ./start.sh llm
# Then run this repo's OR-style arena with the values below.
# AGENT_ARENA_PROVIDER=openai-compatible
# AGENT_ARENA_BASE_URL=http://localhost:8081/v1
# AGENT_ARENA_MODEL_NAME=mistralai/Ministral-3-3B-Instruct-2512-BF16
# AGENT_ARENA_MODEL_LABEL=ministral3b_local
